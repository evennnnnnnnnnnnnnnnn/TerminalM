{
  "name": "terminalm",
  "version": "2.1.0",
  "description": "Modern terminal emulator with tabs, split panes, search, and Catppuccin theme",
  "main": "src/main/main.js",
  "author": "Even",
  "scripts": {
    "start": "electron .",
    "rebuild": "npx @electron/rebuild",
    "dist": "electron-builder --win -c.npmRebuild=false",
    "release": "dotenv -e .env -- electron-builder --win -c.npmRebuild=false --publish always",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.9.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.10.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.4.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.0.0",
    "three": "^0.183.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv-cli": "^11.0.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.0.12",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.even.terminalm",
    "productName": "TerminalM",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "evennnnnnnnnnnnnnnnn",
      "repo": "TerminalM"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
